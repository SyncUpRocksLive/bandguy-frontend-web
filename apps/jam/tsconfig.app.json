{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.dotcache/tsconfig.app.tsbuildinfo",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler", // Crucial for Vite 8 / Node 24
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../../packages/shared/src/*"]
    }
    // ... rest of your settings
  },
  "include": ["src"]
}
